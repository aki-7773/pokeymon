lues/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="version_group_regions" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="108"/><column index="2" value="63"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="version_groups" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="2" mode="1"/></sort><column_widths><column index="1" value="29"/><column index="2" value="202"/><column index="3" value="88"/><column index="4" value="38"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="versions" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="29"/><column index="2" value="108"/><column index="3" value="117"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 5">select pokemon_species.identifier, generations.identifier, version_groups.identifier,
pokemon_habitat_names.name, pokedexes.identifier, pokemon.height, pokemon.weight, abilities.identifier,
type_names.name, pokemon_species.has_gender_differences

from pokemon_species
join generations on pokemon_species.generation_id = generations.id
join version_groups on generations.id = version_groups.generation_id
join pokemon_habitat_names on pokemon_habitat_names.pokemon_habitat_id = pokemon_species.habitat_id
join version_group_regions on version_group_regions.version_group_id = version_groups.id
join pokedexes on pokedexes.region_id = version_group_regions.region_id
join pokemon on pokemon.id = pokemon_species.id
join pokemon_abilities on pokemon.id = pokemon_abilities.pokemon_id
join abilities on abilities.id = pokemon_abilities.ability_id
join pokemon_types on pokemon_types.pokemon_id = pokemon.id
join type_names on type_names.type_id = pokemon_types.type_id
where pokemon_species.identifier = &quot;bulbasaur&quot; and pokemon_habitat_names.local_language_id = 9 and type_names.local_language_id = 9</sql><current_tab id="0"/></tab_sql></sqlb_project>
